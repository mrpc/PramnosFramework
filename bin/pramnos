#!/usr/bin/env php
<?php declare(strict_types=1);

$possibleAutoloadPaths = [
     // dependency
     __DIR__ . '/../../../autoload.php',
     // local dev repository
     __DIR__ . '/../vendor/autoload.php',
];

foreach ($possibleAutoloadPaths as $possibleAutoloadPath) {
    if (file_exists($possibleAutoloadPath)) {
        require_once $possibleAutoloadPath;
        break;
    }
}

if (!defined('ROOT')) {
    $cwd = getcwd();
    // Path if we are in a project that has us as a dependency (handles symlinks)
    $projectVendorPath = $cwd . DIRECTORY_SEPARATOR . 'vendor' . DIRECTORY_SEPARATOR . 'mrpc' . DIRECTORY_SEPARATOR . 'pramnosframework';
    
    if (file_exists($projectVendorPath)) {
        define('ROOT', $cwd);
    } elseif (strpos(__FILE__, DIRECTORY_SEPARATOR . 'vendor' . DIRECTORY_SEPARATOR) !== false) {
        // Standard installation (non-symlinked vendor)
        define('ROOT', dirname(__DIR__, 4));
    } else {
        // Local framework development repository
        define('ROOT', dirname(__DIR__));
    }
}



$app = new \Pramnos\Console\Application();
$app->run();
