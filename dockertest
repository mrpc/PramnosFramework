#!/usr/bin/env bash

# Prevent concurrent test runs: they share the same MySQL/PostgreSQL Docker
# databases, so two overlapping runs will stomp each other's tables and produce
# spurious failures.
#
# Lock strategy: flock on a file descriptor is automatically released when the
# process exits — even on SIGKILL — because the kernel closes all fds.
# The only way the lock can be "stuck" is if the process is still alive but
# hanging (e.g. docker-compose exec frozen). In that case we detect a stale
# PID: if the recorded PID no longer exists, we clear the lock and proceed.
LOCK_FILE="/tmp/dockertest-pramnos.lock"

_acquire_lock() {
    exec 9>"$LOCK_FILE"
    flock -n 9
}

if ! _acquire_lock; then
    existing_pid=$(cat "$LOCK_FILE" 2>/dev/null)
    # Stale lock: the recorded process is no longer running.
    if [[ -n "$existing_pid" ]] && ! kill -0 "$existing_pid" 2>/dev/null; then
        echo "Stale lock detected (PID $existing_pid is gone). Clearing and proceeding." >&2
        rm -f "$LOCK_FILE"
        _acquire_lock || { echo "Could not acquire lock after clearing stale entry." >&2; exit 1; }
    else
        echo "Another ./dockertest run is already in progress (PID: ${existing_pid:-unknown})." >&2
        [[ -n "$existing_pid" ]] && echo "  To kill it:  kill $existing_pid" >&2
        exit 1
    fi
fi
# Record our PID so a subsequent caller can detect staleness.
echo $$ >"$LOCK_FILE"

nobrowser=false
coverage=false
testdox=false
passthrough=()
for arg in "$@"; do
    if [[ "$arg" == "--nobrowser" ]]; then
        nobrowser=true
    elif [[ "$arg" == "--coverage" ]]; then
        coverage=true
    elif [[ "$arg" == "--testdox" ]]; then
        testdox=true
    else
        passthrough+=("$arg")
    fi
done

# Check if containers are running
if ! docker-compose ps | grep -q "pramnos_php.*Up"; then
    echo "Containers not running. Starting them..."
    docker-compose up -d
    echo "Waiting for services to be ready..."
    sleep 10
fi

# Check if database is initialized by accessing the app
echo "Ensuring database is initialized..."
curl -s http://localhost:18081/ > /dev/null 2>&1

# Ensure dependencies are installed
if ! docker-compose exec php-apache-environment test -f vendor/bin/phpunit; then
    echo "Installing composer dependencies..."
    docker-compose exec php-apache-environment composer install
fi

# Run tests
echo -e "\e[32mRunning PHPUnit tests...\e[0m"
extra_flags="--configuration phpunit.xml --display-deprecations --display-warnings --display-incomplete --display-skipped"
[[ "$testdox" == true ]] && extra_flags="$extra_flags --testdox"

if [[ "$coverage" == true ]]; then
    docker-compose exec php-apache-environment vendor/bin/phpunit \
        --coverage-html coverage \
        --coverage-clover coverage/clover.xml \
        $extra_flags "${passthrough[@]}"
else
    docker-compose exec php-apache-environment vendor/bin/phpunit $extra_flags "${passthrough[@]}"
fi

# Open coverage report if generated and not suppressed
if [[ "$coverage" == true && "$nobrowser" == false && -f ./coverage/index.html ]]; then
    if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" || "$OSTYPE" == "linux-gnu"* && "$(uname -r)" == *"Microsoft"* || -n "$WSL_DISTRO_NAME" ]]; then
        win_path=$(wslpath -w "$(pwd)")
        explorer.exe "$win_path\coverage\index.html"
    elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
        xdg-open ./coverage/index.html
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        open ./coverage/index.html
    fi
fi
